{
  "html": "<!DOCTYPE html>\n<html lang='en'>\n<head>\n<meta charset='UTF-8'><meta name='viewport' content='width=device-width,initial-scale=1'>\n<title>Motion RL — Tournament Stats</title>\n<link href='https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:ital,wght@0,300;0,400;0,600;0,700;0,800;1,400&family=Share+Tech+Mono&display=swap' rel='stylesheet'>\n<style>\n:root{\n  --bg:#010306;--surface:#050e1a;--card:#071525;\n  --border:#0c2240;--border2:#0f2d54;\n  --blue:#1565ff;--blue-l:#4d8bff;\n  --gold:#f0c040;--silver:#b8cce0;--bronze:#c87941;\n  --white:#eaf2ff;--text:#b8d4f0;--muted:#3d6080;\n  --danger:#ff3a5c;--success:#22d98a;\n  --gr:#22d98a;--ye:#f0c040;--or:#c87941;--rd:#ff3a5c;\n}\n*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}\nhtml{scroll-behavior:smooth;}\nbody{background:var(--bg);color:var(--text);font-family:'Barlow Condensed',sans-serif;min-height:100vh;overflow-x:hidden;}\n\n/* bg-grid + glow */\n.bg-grid{position:fixed;inset:0;z-index:0;pointer-events:none;\n  background-image:linear-gradient(rgba(21,101,255,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(21,101,255,.03) 1px,transparent 1px);\n  background-size:48px 48px;}\n.bg-glow{position:fixed;top:-300px;left:50%;transform:translateX(-50%);width:1000px;height:600px;z-index:0;pointer-events:none;\n  background:radial-gradient(ellipse,rgba(21,101,255,.10) 0%,transparent 70%);}\n\n/* scanline */\nbody::before{content:'';position:fixed;inset:0;z-index:9000;pointer-events:none;\n  background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,0,0,.015) 3px,rgba(0,0,0,.015) 4px);}\n\n/* ── HEADER ── */\n.hdr{position:relative;z-index:10;border-bottom:1px solid var(--border);overflow:hidden;}\n.hdr-bg{position:absolute;inset:0;\n  background:radial-gradient(ellipse 90% 140% at 50% -20%,rgba(21,101,255,.13) 0%,transparent 65%),\n  linear-gradient(180deg,#020510 0%,var(--bg) 100%);}\n.hdr-grid{position:absolute;inset:0;\n  background-image:linear-gradient(rgba(21,101,255,.07) 1px,transparent 1px),linear-gradient(90deg,rgba(21,101,255,.07) 1px,transparent 1px);\n  background-size:56px 56px;\n  -webkit-mask-image:radial-gradient(ellipse 100% 100% at 50% 0%,black 10%,transparent 80%);\n  mask-image:radial-gradient(ellipse 100% 100% at 50% 0%,black 10%,transparent 80%);}\n.hdr-inner{position:relative;z-index:1;text-align:center;padding:72px 24px 52px;max-width:1200px;margin:0 auto;}\n.hdr-scan{position:absolute;left:0;right:0;height:1px;\n  background:linear-gradient(90deg,transparent,rgba(21,101,255,.55),transparent);\n  animation:scan 5s ease-in-out infinite;pointer-events:none;}\n@keyframes scan{0%{top:5%;opacity:0}10%{opacity:1}90%{opacity:1}100%{top:95%;opacity:0}}\n.logo-wrap img{max-height:80px;max-width:300px;object-fit:contain;margin-bottom:16px;\n  filter:drop-shadow(0 0 28px rgba(21,101,255,.4)) drop-shadow(0 0 60px rgba(21,101,255,.15));}\n.logo-text{font-family:'Bebas Neue',sans-serif;font-size:clamp(56px,10vw,110px);letter-spacing:10px;\n  color:var(--white);line-height:.95;text-shadow:0 0 80px rgba(21,101,255,.35);}\n.logo-text span{color:var(--blue-l);}\n.tagline{font-family:'Share Tech Mono',monospace;font-size:10px;letter-spacing:5px;color:var(--muted);margin-top:14px;text-transform:uppercase;}\n\n/* ── NAV ── */\n.nav{position:sticky;top:0;z-index:200;display:flex;align-items:center;justify-content:center;\n  padding:0 40px;height:60px;background:rgba(1,3,6,.95);border-bottom:1px solid var(--border);backdrop-filter:blur(16px);}\n.nb{font-family:'Share Tech Mono',monospace;font-size:11px;letter-spacing:3px;text-transform:uppercase;\n  color:var(--muted);background:none;border:none;padding:20px 36px;cursor:pointer;\n  position:relative;margin-bottom:-1px;transition:color .2s;}\n.nb::after{content:'';position:absolute;bottom:0;left:50%;right:50%;height:2px;\n  background:var(--blue-l);box-shadow:0 0 12px rgba(21,101,255,.5);\n  transition:left .3s cubic-bezier(.4,0,.2,1),right .3s cubic-bezier(.4,0,.2,1);}\n.nb:hover{color:var(--text);}\n.nb.active{color:var(--white);}\n.nb.active::after{left:0;right:0;}\na.rules-link{text-decoration:none;color:var(--muted);}\na.rules-link:hover{color:var(--blue-l);}\n.live-pill{display:flex;align-items:center;gap:6px;font-family:'Share Tech Mono',monospace;font-size:10px;\n  letter-spacing:2px;color:var(--success);border:1px solid rgba(34,217,138,.3);padding:4px 12px;\n  background:rgba(34,217,138,.05);margin-left:24px;}\n.live-dot{width:6px;height:6px;border-radius:50%;background:var(--success);\n  box-shadow:0 0 8px var(--success);animation:blink 2s infinite;}\n@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}\n\n/* ── SECTIONS ── */\n.sec{display:none;max-width:1300px;margin:0 auto;padding:52px 28px 100px;animation:fadeUp .3s ease;}\n.sec.active{display:block;}\n@keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}\n\n/* ── SECTION LABEL ── */\n.sh{font-family:'Share Tech Mono',monospace;font-size:10px;letter-spacing:4px;color:var(--blue-l);\n  margin-bottom:20px;display:flex;align-items:center;gap:12px;text-transform:uppercase;}\n.sh::after{content:'';flex:1;height:1px;background:var(--border);}\n\n/* ── TOURNAMENT HERO ── */\n.tourn-hero{display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;\n  gap:16px;margin-bottom:44px;padding-bottom:28px;border-bottom:1px solid var(--border);}\n.tourn-name{font-family:'Bebas Neue',sans-serif;font-size:clamp(2rem,5vw,3.8rem);letter-spacing:3px;text-transform:uppercase;line-height:1;color:var(--white);}\n.pills{display:flex;gap:8px;flex-wrap:wrap;align-items:center;}\n.pill{font-family:'Share Tech Mono',monospace;font-size:10px;letter-spacing:2px;\n  color:var(--muted);background:var(--card);border:1px solid var(--border);padding:6px 14px;text-transform:uppercase;}\n\n/* ── STAT CARDS ── */\n.cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:2px;margin-bottom:52px;}\n.card{background:var(--card);border:1px solid var(--border);padding:26px 20px;\n  position:relative;overflow:hidden;transition:transform .2s,box-shadow .2s;cursor:default;}\n.card:hover{transform:translateY(-3px);box-shadow:0 0 40px rgba(21,101,255,.12);}\n.card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;\n  background:linear-gradient(90deg,transparent,var(--blue-l),transparent);opacity:.7;}\n.card-glow{position:absolute;top:-40px;right:-40px;width:120px;height:120px;\n  background:radial-gradient(circle,rgba(21,101,255,.07) 0%,transparent 70%);pointer-events:none;}\n.c-label{font-family:'Share Tech Mono',monospace;font-size:9px;letter-spacing:3px;\n  color:var(--muted);text-transform:uppercase;margin-bottom:10px;}\n.c-val{font-family:'Bebas Neue',sans-serif;font-size:3.2rem;color:var(--blue-l);line-height:1;margin-bottom:6px;\n  text-shadow:0 0 24px rgba(21,101,255,.4);}\n.c-who{font-size:13px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}\n\n/* ── TABLES ── */\n.tw{overflow-x:auto;margin-bottom:52px;border:1px solid var(--border);background:var(--card);}\ntable{width:100%;border-collapse:collapse;font-size:13px;}\nthead tr{background:var(--surface);border-bottom:1px solid var(--border);}\nthead th{font-family:'Share Tech Mono',monospace;font-size:9px;letter-spacing:2px;color:var(--muted);\n  padding:13px 14px;text-align:left;border-bottom:1px solid var(--border);white-space:nowrap;\n  cursor:pointer;user-select:none;transition:color .15s,background .15s;}\nthead th:hover{color:var(--blue-l);background:rgba(21,101,255,.05);}\nthead th.sorted{color:var(--blue-l);}\ntbody tr{border-bottom:1px solid rgba(21,101,255,.05);transition:background .12s;cursor:pointer;}\ntbody tr:hover{background:rgba(21,101,255,.05);}\ntbody tr:last-child{border-bottom:none;}\ntbody tr.gold-row{background:rgba(240,192,64,.035);}\ntbody tr.silver-row{background:rgba(184,204,224,.018);}\ntbody tr.bronze-row{background:rgba(200,121,65,.025);}\ntd{padding:13px 14px;white-space:nowrap;color:var(--text);font-size:14px;font-weight:500;}\ntd.hi{color:var(--white);font-weight:700;}\ntd.num{color:var(--text);font-weight:500;}\ntd.dim{color:var(--muted);}\ntd.pos{color:var(--success);font-weight:600;}\ntd.neg{color:var(--danger);font-weight:600;}\n\n/* rank */\n.rank{font-family:'Bebas Neue',sans-serif;font-size:20px;color:var(--muted);width:48px;text-align:center;}\n.rank.gold{color:var(--gold);}\n.rank.silver{color:var(--silver);}\n.rank.bronze{color:var(--bronze);}\n\n/* player name */\n.pname{font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:1px;color:var(--white);}\n\n/* team tag */\n.ttag{font-family:'Share Tech Mono',monospace;font-size:9px;letter-spacing:2px;\n  color:var(--muted);background:var(--surface);border:1px solid var(--border);padding:3px 9px;}\n\n/* motion rating */\n.mr{display:inline-flex;align-items:baseline;gap:8px;}\n.mr-num{font-family:'Bebas Neue',sans-serif;font-size:24px;font-weight:900;line-height:1;}\n.mr-tag{font-family:'Share Tech Mono',monospace;font-size:8px;letter-spacing:2px;padding:2px 8px;}\n\n/* ── FILTER BAR ── */\n.fbar{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:18px;align-items:center;}\n.fbar input,.fbar select{background:var(--card);border:1px solid var(--border);color:var(--white);\n  font-family:'Share Tech Mono',monospace;font-size:11px;letter-spacing:1px;\n  padding:10px 16px;outline:none;transition:border-color .2s;}\n.fbar input::placeholder{color:var(--muted);}\n.fbar input:focus,.fbar select:focus{border-color:var(--blue-l);}\n.fbar select option{background:var(--card);}\n.fbar input{width:240px;} .fbar select{width:190px;}\n\n/* ── BRACKET ── */\n.bwrap{overflow-x:auto;padding-bottom:24px;margin-bottom:52px;}\n.bracket{display:flex;gap:0;min-width:max-content;align-items:stretch;}\n.bround{display:flex;flex-direction:column;min-width:250px;}\n.bround-matchups{display:flex;flex-direction:column;flex:1;justify-content:space-around;}\n.bround-label{font-family:'Share Tech Mono',monospace;font-size:9px;letter-spacing:3px;\n  color:var(--blue-l);text-transform:uppercase;text-align:center;padding:11px;\n  background:rgba(21,101,255,.05);\n  border-top:1px solid var(--border);border-bottom:2px solid var(--blue-l);margin-bottom:0;}\n.mu{background:var(--card);border:1px solid var(--border);margin:7px 8px;overflow:hidden;transition:border-color .2s;}\n.mu:hover{border-color:rgba(21,101,255,.3);}\n.mu.done{border-color:rgba(21,101,255,.22);}\n.mu-fmt{font-family:'Share Tech Mono',monospace;font-size:8px;letter-spacing:2px;\n  color:var(--muted);padding:5px 12px;background:rgba(0,0,0,.25);border-bottom:1px solid var(--border);text-align:center;}\n.mu-team{display:flex;justify-content:space-between;align-items:center;padding:12px 15px;}\n.mu-team+.mu-team{border-top:1px solid var(--border);}\n.mu-name{font-family:'Bebas Neue',sans-serif;font-size:17px;letter-spacing:1px;color:var(--text);}\n.mu-score{font-family:'Bebas Neue',sans-serif;font-size:26px;color:var(--muted);min-width:30px;text-align:right;}\n.mu-team.win .mu-name{color:var(--success);}\n.mu-team.win .mu-score{color:var(--success);text-shadow:0 0 12px rgba(34,217,138,.5);}\n.mu-team.los .mu-name,.mu-team.los .mu-score{color:var(--muted);}\n.mu-team.tbd .mu-name{color:var(--muted);font-style:italic;font-weight:400;}\n\n/* ── STANDINGS ── */\n.pos-num{font-family:'Bebas Neue',sans-serif;font-size:22px;font-weight:900;width:50px;}\n.p1 .pos-num{color:var(--gold);} .p2 .pos-num{color:var(--silver);} .p3 .pos-num{color:var(--bronze);} .p4 .pos-num{color:var(--muted);}\n\n/* ── UPCOMING ── */\n.upcoming{position:relative;background:var(--card);border:1px solid var(--border);\n  padding:52px 44px;margin-bottom:28px;overflow:hidden;}\n.upcoming::before{content:'';position:absolute;top:0;left:0;bottom:0;\n  width:3px;background:linear-gradient(180deg,var(--blue-l),transparent);}\n.upcoming::after{content:'';position:absolute;inset:0;\n  background:radial-gradient(ellipse 60% 80% at 100% 50%,rgba(21,101,255,.05) 0%,transparent 60%);pointer-events:none;}\n.uname{font-family:'Bebas Neue',sans-serif;font-size:clamp(2rem,5vw,3.8rem);letter-spacing:3px;\n  text-transform:uppercase;line-height:1;margin-bottom:14px;color:var(--white);}\n.udate{font-family:'Share Tech Mono',monospace;font-size:12px;letter-spacing:4px;color:var(--blue-l);margin-bottom:22px;}\n.uprice{display:inline-flex;align-items:center;gap:10px;\n  background:rgba(240,192,64,.05);border:1px solid rgba(240,192,64,.18);\n  color:var(--gold);font-family:'Share Tech Mono',monospace;font-size:11px;\n  letter-spacing:2px;padding:7px 18px;margin-bottom:22px;}\n.udesc{color:var(--text);font-size:14px;line-height:1.85;max-width:640px;margin-bottom:32px;position:relative;z-index:1;}\n.ubtn{display:inline-flex;align-items:center;gap:10px;padding:14px 28px;\n  font-family:'Bebas Neue',sans-serif;font-size:16px;letter-spacing:3px;text-transform:uppercase;\n  text-decoration:none;transition:all .2s;margin-right:14px;margin-bottom:10px;position:relative;z-index:1;}\n.ubtn.discord{background:rgba(88,101,242,.1);border:1px solid rgba(88,101,242,.3);color:#7289da;}\n.ubtn.discord:hover{background:rgba(88,101,242,.22);transform:translateY(-2px);}\n.ubtn.reg{background:rgba(21,101,255,.1);border:1px solid var(--blue-l);color:var(--blue-l);\n  box-shadow:0 4px 24px rgba(21,101,255,.2);}\n.ubtn.reg:hover{background:rgba(21,101,255,.2);transform:translateY(-2px);}\n\n/* ── ARCHIVE ── */\n.arc-item{background:var(--card);border:1px solid var(--border);margin-bottom:2px;overflow:hidden;transition:border-color .2s;}\n.arc-item:hover{border-color:var(--border2);}\n.arc-hdr{display:flex;justify-content:space-between;align-items:center;\n  padding:22px 28px;cursor:pointer;user-select:none;transition:background .15s;}\n.arc-hdr:hover{background:rgba(21,101,255,.03);}\n.arc-title{font-family:'Bebas Neue',sans-serif;font-size:1.6rem;letter-spacing:2px;text-transform:uppercase;color:var(--white);}\n.arc-meta{font-family:'Share Tech Mono',monospace;font-size:10px;letter-spacing:1px;color:var(--muted);margin-top:5px;}\n.arc-right{display:flex;align-items:center;gap:24px;}\n.arc-mr-label{font-family:'Share Tech Mono',monospace;font-size:8px;letter-spacing:2px;color:var(--muted);margin-bottom:2px;}\n.arc-mr-val{font-family:'Bebas Neue',sans-serif;font-size:1.6rem;font-weight:900;}\n.arc-mr-name{font-size:11px;color:var(--muted);}\n.chevron{font-size:22px;color:var(--muted);transition:transform .28s cubic-bezier(.4,0,.2,1),color .2s;line-height:1;}\n.arc-hdr.open .chevron{transform:rotate(90deg);color:var(--blue-l);}\n.arc-body{display:none;padding:28px;border-top:1px solid var(--border);background:rgba(0,0,0,.18);}\n.arc-body.open{display:block;animation:fadeUp .22s ease;}\n\n/* ── FOOTER ── */\nfooter{position:relative;z-index:10;border-top:1px solid var(--border);padding:28px 40px;\n  display:flex;align-items:center;justify-content:space-between;max-width:1300px;margin:0 auto;}\n.ft-logo{font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:8px;color:var(--muted);}\n.ft-logo span{color:var(--blue);}\n.ft-meta{font-family:'Share Tech Mono',monospace;font-size:9px;letter-spacing:2px;color:var(--border2);}\n\n@media(max-width:768px){\n  .hdr-inner{padding:48px 16px 36px;}\n  .nav{padding:0 12px;}\n  .nb{padding:16px 16px;font-size:10px;letter-spacing:2px;}\n  .sec{padding:36px 14px 64px;}\n  .cards{grid-template-columns:repeat(2,1fr);}\n  .tourn-hero{flex-direction:column;align-items:flex-start;}\n  .bround{min-width:190px;}\n  .upcoming{padding:36px 22px;}\n  footer{flex-direction:column;gap:10px;text-align:center;}\n}\n</style>\n</head>\n<body>\n\n<div class='bg-grid'></div>\n<div class='bg-glow'></div>\n\n<header class='hdr'>\n  <div class='hdr-bg'></div>\n  <div class='hdr-grid'></div>\n  <div class='hdr-scan'></div>\n  <div class='hdr-inner'>\n    <div class='logo-wrap'>\n      <img src='logo.png' alt='Motion RL' onerror='this.style.display=\"none\";document.getElementById(\"ltxt\").style.display=\"block\"'>\n      <div class='logo-text' id='ltxt' style='display:none'>MOTI<span>ON</span> RL</div>\n    </div>\n    <div class='tagline'>// Motion Rocket League &nbsp;·&nbsp; Official Tournament Stats &nbsp;·&nbsp; Motion Rating™</div>\n  </div>\n</header>\n\n<nav class='nav'>\n  <button class='nb active' onclick='showTab(\"current\",this)'>Current Tournament</button>\n  <button class='nb' onclick='showTab(\"upcoming\",this)'>Upcoming</button>\n  <button class='nb' onclick='showTab(\"archive\",this)'>Archive</button>\n  <a class='nb rules-link' href='https://motioncommunity.github.io/official-rules/' target='_blank' rel='noopener'>Rules ↗</a>\n  <div class='live-pill'><div class='live-dot'></div>LIVE</div>\n</nav>\n\n<section class='sec active' id='tab-current'>\n<div class='tourn-hero'>\n  <div><div class='tourn-name'>Q1 Inaugural 2v2</div></div>\n  <div class='pills'>\n    <span class='pill'>SingleElimination</span>\n    <span class='pill'>3 games</span>\n    <span class='pill'>12 players</span>\n    <span class='pill'>1 teams</span>\n  </div>\n</div>\n<div class='sh'>Tournament Highlights</div>\n<div class='cards'>\n  <div class='card'><div class='card-glow'></div><div class='c-label'>Top Motion Rating</div><div class='c-val'>472</div><div class='c-who'>ψCancer</div></div>\n  <div class='card'><div class='card-glow'></div><div class='c-label'>Most Goals</div><div class='c-val'>5</div><div class='c-who'>Uncle Rico</div></div>\n  <div class='card'><div class='card-glow'></div><div class='c-label'>Most Saves</div><div class='c-val'>5</div><div class='c-who'>Uncle Rico</div></div>\n  <div class='card'><div class='card-glow'></div><div class='c-label'>Most Assists</div><div class='c-val'>3</div><div class='c-who'>Uncle Rico</div></div>\n  <div class='card'><div class='card-glow'></div><div class='c-label'>Most Demos</div><div class='c-val'>2</div><div class='c-who'>Uncle Rico</div></div>\n  <div class='card'><div class='card-glow'></div><div class='c-label'>Total Games</div><div class='c-val'>3</div><div class='c-who'>This tournament</div></div>\n</div>\n\n<div class='sh'>Bracket</div>\n<div class='bwrap'><p style='color:var(--tx3);font-family:Share Tech Mono,monospace;letter-spacing:2px;font-size:11px;padding:20px 0'>BRACKET NOT YET SET UP</p></div>\n<div class='sh'>Motion Rating™ Leaderboard</div>\n<div class='fbar'>\n  <input id='ps' type='text' placeholder='Search player...' oninput='filterLb()'>\n  <select id='tmf' onchange='filterLb()'>\n    <option value=''>All Teams</option><option value='test'>test</option>\n  </select>\n</div>\n<div class='tw'>\n<table id='lbt' data-sc='' data-sd=''>\n<thead><tr>\n  <th onclick='sortTable(\"lbt\",0)'>#</th>\n  <th onclick='sortTable(\"lbt\",1)'>Player</th>\n  <th onclick='sortTable(\"lbt\",2)'>Team</th>\n  <th onclick='sortTable(\"lbt\",3)'>Motion Rating</th>\n  <th onclick='sortTable(\"lbt\",4)'>Goals</th>\n  <th onclick='sortTable(\"lbt\",5)'>Assists</th>\n  <th onclick='sortTable(\"lbt\",6)'>Saves</th>\n  <th onclick='sortTable(\"lbt\",7)'>Shots</th>\n  <th onclick='sortTable(\"lbt\",8)'>Acc%</th>\n  <th onclick='sortTable(\"lbt\",9)'>Avg G</th>\n  <th onclick='sortTable(\"lbt\",10)'>Avg S</th>\n  <th onclick='sortTable(\"lbt\",11)'>Avg Sc</th>\n  <th onclick='sortTable(\"lbt\",12)'>Demo+</th>\n  <th onclick='sortTable(\"lbt\",13)'>Demo-</th>\n  <th onclick='sortTable(\"lbt\",14)'>Net</th>\n  <th onclick='sortTable(\"lbt\",15)'>MVPs</th>\n  <th onclick='sortTable(\"lbt\",16)'>MVP%</th>\n  <th onclick='sortTable(\"lbt\",17)'>W/L</th>\n  <th onclick='sortTable(\"lbt\",18)'>Win%</th>\n  <th onclick='sortTable(\"lbt\",19)'>GP</th>\n</tr></thead>\n<tbody><tr class='gold-row'>\n<td class='rank gold'>01</td>\n<td><span class='pname'>Uncle Rico</span></td>\n<td><span class='dim'>—</span></td>\n<td><span class='mr'><span class='mr-num' style='color:#4d96ff'>367</span><span class='mr-tag' style='color:#4d96ff;border:1px s