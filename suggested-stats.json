);\n  const tm=(document.getElementById('tmf')?.value||'').toLowerCase();\n  document.querySelectorAll('#lbt tbody tr').forEach(r=>{\n    const n=(r.cells[1]?.textContent||'').toLowerCase();\n    const t=(r.cells[2]?.textContent||'').toLowerCase();\n    r.style.display=(!q||n.includes(q))&&(!tm||t.includes(tm))?'':'none';\n  });\n}\nfunction sortTable(id,col){\n  const tbl=document.getElementById(id);\n  const tbody=tbl.querySelector('tbody');\n  const rows=Array.from(tbody.querySelectorAll('tr'));\n  const asc=tbl.dataset.sc==col&&tbl.dataset.sd=='asc';\n  rows.sort((a,b)=>{\n    const av=a.cells[col]?.textContent.trim()||'';\n    const bv=b.cells[col]?.textContent.trim()||'';\n    const an=parseFloat(av),bn=parseFloat(bv);\n    if(!isNaN(an)&&!isNaN(bn))return asc?an-bn:bn-an;\n    return asc?av.localeCompare(bv):bv.localeCompare(av);\n  });\n  rows.forEach(r=>tbody.appendChild(r));\n  tbl.dataset.sc=col; tbl.dataset.sd=asc?'desc':'asc';\n  tbl.querySelectorAll('thead th').forEach((th,i)=>{\n    th.textContent=th.textContent.replace(/\\s*[\\u2191\\u2193]$/,'');\n    if(i==col)th.textContent+=asc?' \\u2193':' \\u2191';\n    th.classList.toggle('sorted',i==col);\n  });\n}\nfunction toggleArc(id){\n  document.getElementById('ab-'+id).classList.toggle('open');\n  document.getElementById('ah-'+id).classList.toggle('open');\n}\n</script>\n</body></html>",
